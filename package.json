{
  "name": "noble-wave",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:all": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "build:prod": "ng build -c production --base-href https://noble-wave.com",
    "dist": "npx angular-cli-ghpages --dir=dist/noble-wave/browser",
    "dist:ng2": "ng deploy --cname=noble-wave.com --no-silent --branch=gh-pages --base-href=https://noble-wave.com",
    "dist:ng": "ng deploy --branch=gh-pages --base-href=https://noble-wave.com --no-silent",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "aos": "^2.3.4",
    "lottie-web": "^5.13.0",
    "lucide": "^1.14.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "~21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/aos": "^3.0.7",
    "angular-cli-ghpages": "^3.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  }
}
